<Window x:Class="VideoWall.Views.TextEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CPE · Texto"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgApp}">
    <Border Background="{StaticResource CardInk}" Margin="14">
        <StackPanel Margin="16">
            <TextBlock Text="TEXTO NA PAREDE" Style="{StaticResource SectionLabel}"/>

            <TextBlock Text="Escreva o texto" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TextBox" Style="{StaticResource NumberBox}" AcceptsReturn="True"
                     TextWrapping="Wrap" Height="90" VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tamanho" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SizeBox" Style="{StaticResource NumberBox}" Width="80" Margin="0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock Text="Cor do texto" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="CW" Width="26" Height="26" CornerRadius="13" Margin="0,0,6,0"
                                Background="#FFFFFF" Cursor="Hand" Tag="#FFFFFF" BorderBrush="#F2B705"
                                BorderThickness="0" MouseLeftButtonDown="OnColor"/>
                        <Border x:Name="CG" Width="26" Height="26" CornerRadius="13" Margin="0,0,6,0"
                                Background="#F2B705" Cursor="Hand" Tag="#F2B705" BorderBrush="#F2B705"
                                BorderThickness="0" MouseLeftButtonDown="OnColor"/>
                        <Border x:Name="CR" Width="26" Height="26" CornerRadius="13" Margin="0,0,6,0"
                                Background="#EF4444" Cursor="Hand" Tag="#EF4444" BorderBrush="#F2B705"
                                BorderThickness="0" MouseLeftButtonDown="OnColor"/>
                        <Border x:Name="CGr" Width="26" Height="26" CornerRadius="13" Margin="0,0,6,0"
                                Background="#22C55E" Cursor="Hand" Tag="#22C55E" BorderBrush="#F2B705"
                                BorderThickness="0" MouseLeftButtonDown="OnColor"/>
                        <Border x:Name="CB" Width="26" Height="26" CornerRadius="13" Margin="0,0,6,0"
                                Background="#3B82F6" Cursor="Hand" Tag="#3B82F6" BorderBrush="#F2B705"
                                BorderThickness="0" MouseLeftButtonDown="OnColor"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <TextBlock Text="Dica: o texto aparece por cima na TV. Use ↑ Frente / ↓ Trás para ajustar a ordem."
                       Foreground="#6B7280" FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancelar" Width="100" Margin="0,0,8,0" IsCancel="True"
                        Style="{StaticResource SubtleButton}"/>
                <Button Content="Salvar" Width="120" IsDefault="True" Click="OnSave"
                        Style="{StaticResource PanelButton}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
