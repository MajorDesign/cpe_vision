<Window x:Class="VideoWall.Views.SchedulerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CPE · Agendador e rotação de layouts"
        Height="820" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Window.Resources>
        <Style x:Key="DayChk" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource OnDark}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardInk}" Margin="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <!-- ============ POR HORÁRIO ============ -->
                <TextBlock Text="AGENDAMENTO POR HORÁRIO" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>
                <TextBlock Text="Projeta um layout numa tela em um horário"
                           Foreground="{StaticResource OnDark}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Border Background="{StaticResource InputBg}" BorderBrush="{StaticResource HairDark}"
                        BorderThickness="1" Height="150">
                    <ListBox ItemsSource="{Binding Schedules}" SelectedItem="{Binding SelectedSchedule}"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource OnDark}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center"
                                              Margin="0,0,10,0" ToolTip="Ativar/desativar"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="{StaticResource Gold}"
                                               FontFamily="Consolas" FontSize="16" FontWeight="Bold" Width="64"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LayoutName}" Foreground="{StaticResource OnDark}" FontSize="13"/>
                                            <TextBlock Text="{Binding ScreenText}" Foreground="{StaticResource Gold}"
                                                       FontSize="13" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DaysText}" Foreground="{StaticResource OnDarkMuted}"
                                                   FontFamily="Consolas" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Hora" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource NumberBox}" Width="50" Margin="0"
                                 Text="{Binding NewScheduleHour, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Min" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource NumberBox}" Width="50" Margin="0"
                                 Text="{Binding NewScheduleMinute, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Layout" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Layouts}" SelectedItem="{Binding NewScheduleLayout}" Padding="6,4"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Tela (terminal de destino)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding RemoteScreens}" SelectedItem="{Binding NewScheduleScreen}"
                          DisplayMemberPath="Name" Padding="6,4"/>

                <TextBlock Text="Dias (nenhum marcado = todos os dias)" Style="{StaticResource FieldLabel}" Margin="0,10,0,4"/>
                <WrapPanel>
                    <CheckBox Content="Dom" IsChecked="{Binding DaySun}" Style="{StaticResource DayChk}"/>
                    <CheckBox Content="Seg" IsChecked="{Binding DayMon}" Style="{StaticResource DayChk}"/>
                    <CheckBox Content="Ter" IsChecked="{Binding DayTue}" Style="{StaticResource DayChk}"/>
                    <CheckBox Content="Qua" IsChecked="{Binding DayWed}" Style="{StaticResource DayChk}"/>
                    <CheckBox Content="Qui" IsChecked="{Binding DayThu}" Style="{StaticResource DayChk}"/>
                    <CheckBox Content="Sex" IsChecked="{Binding DayFri}" Style="{StaticResource DayChk}"/>
                    <CheckBox Content="Sáb" IsChecked="{Binding DaySat}" Style="{StaticResource DayChk}"/>
                </WrapPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Remover" Width="100" Margin="0,0,8,0"
                            Command="{Binding RemoveScheduleCommand}" Style="{StaticResource SubtleButton}"/>
                    <Button Content="Adicionar" Width="120"
                            Command="{Binding AddScheduleCommand}" Style="{StaticResource PanelButton}"/>
                </StackPanel>

                <Separator Margin="0,18" Background="{StaticResource HairDark}"/>

                <!-- ============ ROTAÇÃO AUTOMÁTICA ============ -->
                <TextBlock Text="ROTAÇÃO AUTOMÁTICA" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>
                <TextBlock Text="Troca entre vários layouts a cada X minutos (com play)"
                           Foreground="{StaticResource OnDark}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Tela (terminal)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding RemoteScreens}" SelectedItem="{Binding RotationScreen}"
                                  DisplayMemberPath="Name" Padding="6,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Trocar a cada (min)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource NumberBox}" Width="80" Margin="0"
                                 Text="{Binding RotationMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Sequência de layouts (na ordem da troca)" Style="{StaticResource FieldLabel}" Margin="0,10,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Layouts}" SelectedItem="{Binding RotationPickLayout}"
                              Padding="6,4"/>
                    <Button Grid.Column="1" Content="➕ Adicionar" Width="120" Margin="8,0,0,0"
                            Command="{Binding AddRotationLayoutCommand}" Style="{StaticResource SubtleButton}"/>
                </Grid>

                <Border Background="{StaticResource InputBg}" BorderBrush="{StaticResource HairDark}"
                        BorderThickness="1" Height="110" Margin="0,8,0,0">
                    <ListBox ItemsSource="{Binding RotationLayouts}" SelectedItem="{Binding SelectedRotationLayout}"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource OnDark}"
                             FontSize="13"/>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Remover da sequência" Width="180" Margin="0,0,8,0"
                            Command="{Binding RemoveRotationLayoutCommand}" Style="{StaticResource SubtleButton}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                    <Button Content="▶ Iniciar rotação" Width="160" Margin="0,0,8,0"
                            Command="{Binding StartRotationCommand}" Style="{StaticResource PanelButton}"/>
                    <Button Content="■ Parar" Width="100"
                            Command="{Binding StopRotationCommand}" Style="{StaticResource SubtleButton}"/>
                    <Ellipse Width="9" Height="9" Margin="14,0,8,0" VerticalAlignment="Center"
                             Fill="{StaticResource Gold}"/>
                    <TextBlock Text="{Binding RotationStatus}" Foreground="{StaticResource OnDarkMuted}"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <Separator Margin="0,18,0,12" Background="{StaticResource HairDark}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding SchedulerToggleText}" Width="210" Margin="0,0,8,0"
                            Command="{Binding ToggleSchedulerCommand}" Style="{StaticResource PanelButton}"
                            ToolTip="Pausa/retoma os agendamentos POR HORÁRIO (a rotação tem o próprio Parar)"/>
                    <Button Content="Fechar" Width="100" Click="OnClose" Style="{StaticResource SubtleButton}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
