<Window x:Class="VideoWall.Views.CameraTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VideoWall.Views"
        Title="Teste de câmera / stream"
        Height="500" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <views:CameraView x:Name="Cam" Grid.Row="0"/>
        <TextBlock x:Name="UrlText" Grid.Row="1" Foreground="#9CA3AF" FontSize="11"
                   Padding="8,6" TextTrimming="CharacterEllipsis" Background="#11111B"/>
    </Grid>
</Window>
