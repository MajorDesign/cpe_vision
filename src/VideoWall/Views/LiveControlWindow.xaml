<Window x:Class="VideoWall.Views.LiveControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CPE · Controle ao vivo"
        Width="1180" Height="820"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Window.Resources>
        <!-- Botão da barra de apresentação -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="{StaticResource OnDark}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1B1D22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="#2A2D34"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#262931"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardInk}" Margin="14">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Ellipse x:Name="LiveDot" Width="11" Height="11" Fill="#EF4444" VerticalAlignment="Center"/>
                <TextBlock x:Name="LiveLabel" Text="AO VIVO" Foreground="#EF4444" FontWeight="Bold"
                           FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TargetLabel" Foreground="{StaticResource OnDarkMuted}" FontSize="12"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,10,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UrlBox" Grid.Column="0" Style="{StaticResource NumberBox}"
                         KeyDown="OnUrlKeyDown"/>
                <Button Grid.Column="1" Content="Ir" Width="90" Margin="8,0,0,0"
                        Click="OnGo" Style="{StaticResource SubtleButton}"
                        ToolTip="Abre o endereço aqui e no terminal."/>
            </Grid>

            <!-- Barra de apresentação: ferramentas + cores + zoom -->
            <Border Grid.Row="2" Background="#141519" BorderBrush="#2A2D34" BorderThickness="1"
                    CornerRadius="8" Padding="8,6" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FERRAMENTAS" Foreground="{StaticResource Gold}" FontSize="10"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="2,0,10,0"/>
                    <Button x:Name="ToolCursor" Content="🖱" Style="{StaticResource ToolButton}"
                            Tag="cursor" Click="OnToolClick" ToolTip="Cursor (interagir com a página)"/>
                    <Button x:Name="ToolPen" Content="✏" Style="{StaticResource ToolButton}"
                            Tag="pen" Click="OnToolClick" ToolTip="Caneta (desenho livre)"/>
                    <Button x:Name="ToolArrow" Content="↗" Style="{StaticResource ToolButton}"
                            Tag="arrow" Click="OnToolClick" ToolTip="Seta"/>
                    <Button x:Name="ToolRect" Content="▭" Style="{StaticResource ToolButton}"
                            Tag="rect" Click="OnToolClick" ToolTip="Retângulo"/>
                    <Button x:Name="ToolMarker" Content="🖍" Style="{StaticResource ToolButton}"
                            Tag="marker" Click="OnToolClick" ToolTip="Marca-texto (realce)"/>

                    <Border Width="1" Background="#2A2D34" Margin="10,2"/>

                    <Border x:Name="ColorRed" Width="22" Height="22" CornerRadius="11" Margin="3,0"
                            Background="#EF4444" Cursor="Hand" Tag="#EF4444"
                            MouseLeftButtonDown="OnColorClick" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    <Border x:Name="ColorYellow" Width="22" Height="22" CornerRadius="11" Margin="3,0"
                            Background="#F2B705" Cursor="Hand" Tag="#F2B705"
                            MouseLeftButtonDown="OnColorClick" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    <Border x:Name="ColorGreen" Width="22" Height="22" CornerRadius="11" Margin="3,0"
                            Background="#22C55E" Cursor="Hand" Tag="#22C55E"
                            MouseLeftButtonDown="OnColorClick" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    <Border x:Name="ColorWhite" Width="22" Height="22" CornerRadius="11" Margin="3,0"
                            Background="#FFFFFF" Cursor="Hand" Tag="#FFFFFF"
                            MouseLeftButtonDown="OnColorClick" BorderBrush="#FFFFFF" BorderThickness="0"/>

                    <Button Content="🗑 Limpar" Style="{StaticResource SubtleButton}" Width="92" Margin="12,0,0,0"
                            Click="OnClearAnnotations" ToolTip="Apaga as marcações da TV"/>

                    <Border Width="1" Background="#2A2D34" Margin="12,2"/>

                    <TextBlock Text="ZOOM" Foreground="{StaticResource Gold}" FontSize="10"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="−" Style="{StaticResource ToolButton}" Click="OnZoomOut"/>
                    <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="{StaticResource OnDark}"
                               FontSize="12" Width="46" TextAlignment="Center" VerticalAlignment="Center"/>
                    <Button Content="+" Style="{StaticResource ToolButton}" Click="OnZoomIn"/>
                    <Button Content="⟲" Style="{StaticResource ToolButton}" Click="OnZoomReset"
                            ToolTip="Voltar para 100%"/>
                </StackPanel>
            </Border>

            <!-- Espelho da página (mantém a proporção da célula) + camada de desenho -->
            <Border Grid.Row="3" Background="#0B1220" BorderBrush="#1F2937" BorderThickness="1">
                <Grid x:Name="MirrorHost" SizeChanged="OnMirrorHostSizeChanged" ClipToBounds="True">
                    <Grid x:Name="AspectBox" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <wv2:WebView2 x:Name="Web"/>
                        <!-- Vista congelada (snapshot) usada durante a marcação -->
                        <Image x:Name="Snapshot" Stretch="Fill" Visibility="Collapsed" IsHitTestVisible="False"/>
                        <Canvas x:Name="DrawOverlay" Background="Transparent" Visibility="Collapsed"
                                MouseLeftButtonDown="OnDrawDown" MouseMove="OnDrawMove"
                                MouseLeftButtonUp="OnDrawUp"/>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <TextBlock x:Name="Hint" VerticalAlignment="Center" Margin="0,0,16,0"
                           Foreground="#6B7280" FontSize="12"
                           Text="Cursor: interage com a página. Caneta/seta/retângulo: marca na TV."/>
                <Button Content="Encerrar controle" Width="170" IsCancel="True"
                        Click="OnClose" Style="{StaticResource PanelButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
