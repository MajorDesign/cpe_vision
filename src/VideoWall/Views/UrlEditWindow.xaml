<Window x:Class="VideoWall.Views.UrlEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CPE · Endereço do navegador"
        Width="940" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Border Background="{StaticResource CardInk}" Margin="14">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ENDEREÇO DA PÁGINA" Style="{StaticResource SectionLabel}"/>

            <Grid Grid.Row="1" Margin="0,4,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UrlBox" Grid.Column="0" Style="{StaticResource NumberBox}"
                         KeyDown="OnUrlKeyDown"/>
                <Button Grid.Column="1" Content="Pré-visualizar" Width="130" Margin="8,0,0,0"
                        Click="OnLoad" Style="{StaticResource SubtleButton}"
                        ToolTip="Mostra a página aqui no controlador (não envia ao terminal)."/>
            </Grid>

            <Border Grid.Row="2" Background="#0B1220" BorderBrush="#1F2937" BorderThickness="1">
                <wv2:WebView2 x:Name="Web"/>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <TextBlock x:Name="Hint" Text="A pré-visualização fica só aqui. Use ▶ ENVIAR PARA A TELA para abrir no terminal."
                           Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <Button Content="Cancelar" Width="110" Margin="0,0,8,0" IsCancel="True"
                        Style="{StaticResource SubtleButton}"/>
                <Button x:Name="SaveButton" Content="▶ Enviar para a tela" Width="190" IsDefault="True"
                        Click="OnSave" Style="{StaticResource PanelButton}"
                        ToolTip="Salva a URL e projeta esta página na tela de rede selecionada."/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
