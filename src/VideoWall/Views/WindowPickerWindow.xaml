<Window x:Class="VideoWall.Views.WindowPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CPE · Selecionar janela"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}"
        ResizeMode="CanResize">
    <Border Background="{StaticResource CardInk}" Margin="16">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="ESPELHAR APLICATIVO" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>
                <TextBlock Text="Escolha a janela a espelhar" Foreground="{StaticResource OnDark}"
                           FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource InputBg}" BorderBrush="{StaticResource HairDark}"
                    BorderThickness="1">
                <ListBox x:Name="WindowsList"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource OnDark}" FontSize="13"
                         MouseDoubleClick="OnListDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Padding="4" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancelar" Width="100" Margin="0,0,8,0"
                        Click="OnCancel" Style="{StaticResource SubtleButton}"/>
                <Button Content="Espelhar" Width="120"
                        Click="OnConfirm" Style="{StaticResource PanelButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
