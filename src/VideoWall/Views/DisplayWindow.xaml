<Window x:Class="VideoWall.Views.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VideoWall.Views"
        Title="VideoWall - Saída"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black"
        AllowsTransparency="False">
    <!--
      Janela de saída sem bordas posicionada exatamente sobre um monitor.
      A superfície é deslocada por (OffsetX, OffsetY) = (-monitor.X, -monitor.Y)
      para mostrar o recorte correto da parede virtual.
    -->
    <Grid>
        <views:WallSurfaceView x:Name="Surface"/>
    </Grid>
</Window>
