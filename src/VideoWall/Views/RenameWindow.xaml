<Window x:Class="VideoWall.Views.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CPE · Editar nome"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgApp}">
    <Border Background="{StaticResource CardInk}" Margin="14">
        <StackPanel Margin="16">
            <TextBlock Text="EDITAR NOME" Style="{StaticResource SectionLabel}"/>
            <TextBlock Text="Nome da fonte" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource NumberBox}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Cancelar" Width="100" Margin="0,0,8,0" IsCancel="True"
                        Style="{StaticResource SubtleButton}"/>
                <Button Content="Salvar" Width="110" IsDefault="True" Click="OnSave"
                        Style="{StaticResource PanelButton}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
