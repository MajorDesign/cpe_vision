<Window x:Class="VideoWall.Viewer.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        Width="460" Height="320" ShowInTaskbar="False" Topmost="True">
    <Border Background="#0E0F12" BorderBrush="#26272E" BorderThickness="1" CornerRadius="14">
        <Grid Margin="34,30,34,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo CPE com pulso (batida de coração) -->
                <Grid x:Name="Logo" Width="58" Height="58" HorizontalAlignment="Center" Margin="0,0,0,16"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1"/>
                    </Grid.RenderTransform>
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoScale"
                                            Storyboard.TargetProperty="ScaleX">
                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.18"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.42" Value="1.12"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.56" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="1"/>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoScale"
                                            Storyboard.TargetProperty="ScaleY">
                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.18"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.42" Value="1.12"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.56" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="1"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
                    <Ellipse Stroke="#F2B705" StrokeThickness="3"/>
                    <Ellipse Width="22" Stroke="#F2B705" StrokeThickness="2" HorizontalAlignment="Center"/>
                    <Rectangle Height="2" Fill="#F2B705" VerticalAlignment="Center"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="CPE" FontSize="30" FontWeight="Bold" Foreground="#F2F0E8"/>
                    <TextBlock Text="Tecnologia" FontSize="30" Foreground="#F2B705" Margin="9,0,0,0"/>
                </StackPanel>
                <TextBlock Text="VIDEOWALL · TERMINAL" FontFamily="Consolas" FontSize="12"
                           Foreground="#9A9B92" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <ProgressBar Grid.Row="1" Height="3" IsIndeterminate="True" Margin="0,18,0,12"
                         Background="#1B1D22" Foreground="#F2B705" BorderThickness="0"/>

            <Grid Grid.Row="2">
                <TextBlock x:Name="StatusText" Text="Iniciando…" Foreground="#9A9B92"
                           FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Text="v—" Foreground="#6B7280" FontFamily="Consolas"
                           FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Assinatura com "luz" amarela passando pelas letras (shimmer em loop) -->
            <TextBlock Grid.Row="3" Text="Desenvolvido por Jonathan Lopes"
                       FontSize="11" HorizontalAlignment="Center" Margin="0,14,0,0">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <LinearGradientBrush.GradientStops>
                            <GradientStop Color="#5A5B62" Offset="0.0"/>
                            <GradientStop Color="#5A5B62" Offset="0.42"/>
                            <GradientStop Color="#FFF3C4" Offset="0.5"/>
                            <GradientStop Color="#F2B705" Offset="0.5"/>
                            <GradientStop Color="#5A5B62" Offset="0.58"/>
                            <GradientStop Color="#5A5B62" Offset="1.0"/>
                        </LinearGradientBrush.GradientStops>
                        <LinearGradientBrush.RelativeTransform>
                            <TranslateTransform x:Name="ShineTransform" X="-0.7"/>
                        </LinearGradientBrush.RelativeTransform>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShineTransform"
                                        Storyboard.TargetProperty="X">
                                    <LinearDoubleKeyFrame KeyTime="0:0:0" Value="-0.7"/>
                                    <LinearDoubleKeyFrame KeyTime="0:0:1.7" Value="0.7"/>
                                    <LinearDoubleKeyFrame KeyTime="0:0:3.2" Value="0.7"/>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
        </Grid>
    </Border>
</Window>
